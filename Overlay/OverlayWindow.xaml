<Window x:Class="JKWMonitor.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="clr-namespace:XamlAnimatedGif;assembly=XamlAnimatedGif"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Black"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="200" Height="220"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonUp="Window_MouseRightButtonUp">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top half: raw payload debug view -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button x:Name="CopyLogsButton"
                    Grid.Row="0"
                    Content="Copy logs"
                    HorizontalAlignment="Right"
                    Margin="0,2,4,2"
                    Padding="6,0"
                    FontFamily="Consolas" FontSize="9"
                    Background="#333333" Foreground="#00FF00"
                    BorderBrush="#00FF00" BorderThickness="1"
                    Cursor="Hand"
                    Click="CopyLogsButton_Click" />
            <TextBox x:Name="RawPayloadText"
                     Grid.Row="1"
                     Foreground="#00FF00" Background="#CC000000"
                     FontFamily="Consolas" FontSize="9"
                     TextWrapping="Wrap" Padding="4"
                     IsReadOnly="True"
                     BorderThickness="0"
                     VerticalScrollBarVisibility="Auto"
                     CaretBrush="#00FF00" />
        </Grid>

        <!-- Bottom half: animation -->
        <Grid Grid.Row="1">
            <Image x:Name="IdleAnim"    Visibility="Visible" />
            <Image x:Name="WorkingAnim" Visibility="Collapsed" />
            <Image x:Name="WaitingAnim" Visibility="Collapsed" />
            <Image x:Name="ErrorAnim"   Visibility="Collapsed" />
            <Image x:Name="SuccessAnim" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
