            "type": "command",
            "command": "powershell -NoProfile -File D:/Projekty/HonestJKW/hooks/jkw-monitor.ps1",
            "timeout": 3
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File D:/Projekty/HonestJKW/hooks/jkw-monitor.ps1",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File D:/Projekty/HonestJKW/hooks/jkw-monitor.ps1",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File D:/Projekty/HonestJKW/hooks/jkw-monitor.ps1",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
